{
  "name": "homebridge-dreame-vacuum-mqtt",
  "version": "1.0.0",
  "description": "Matter-native Homebridge v2 plugin for Dreame vacuum robots via Dreame Cloud + MQTT",
  "displayName": "Dreame Vacuum Matter",
  "license": "Apache-2.0",
  "author": "Inaki Etxeba",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "watch": "tsc -w",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --coverage",
    "vitest": "vitest run",
    "type-check": "tsc --noEmit",
    "coverage": "vitest run --coverage",
    "prepack": "npm run build",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "config.schema.json"
  ],
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "matter",
    "dreame",
    "vacuum",
    "robot-vacuum",
    "mqtt"
  ],
  "engines": {
    "node": "^22.12.0 || ^24.0.0",
    "homebridge": ">=2.0.0-beta.0"
  },
  "dependencies": {
    "mqtt": "^5.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "homebridge": "^2.0.0-beta.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1",
    "@vitest/coverage-v8": "^3.2.1"
  }
}
